weight = mrnet_network[edges]
)
# 9. 使用阈值 0.5 筛选边列表
threshold <- 0.5
filtered_edge_list <- edge_list %>% filter(weight > threshold)
# 10. 保存筛选后的网络为 CSV 文件（不包含双引号）
write.csv(filtered_edge_list, "normal_miRNA_network_mrnet_threshold_0.5.csv", row.names = FALSE, quote = FALSE)
print(paste("正常样本的 miRNA 网络已保存为 'normal_miRNA_network_mrnet_threshold_0.5.csv'，阈值 =", threshold))
# 1. 安装并加载所需的包
library(minet)
library(dplyr)
# 2. 加载 miRNA 表达矩阵
miRNA_data <- read.csv("miRNA_HiSeq_gene_filtered.tsv", sep = "\t", row.names = 1, check.names = FALSE)
# 3. 提取以 11 结尾的样本（正常样本）
samples_11 <- colnames(miRNA_data)[grepl("11$", colnames(miRNA_data))]
miRNA_data_11 <- miRNA_data[, samples_11, drop = FALSE]
# 4. 处理缺失值，用 0 补齐
miRNA_data_11[is.na(miRNA_data_11)] <- 0
# 5. 删除所有表达值均为 0 的 miRNA
zero_expression_miRNAs <- rowSums(miRNA_data_11) == 0
miRNA_data_11_filtered <- miRNA_data_11[!zero_expression_miRNAs, ]
# 打印被删除的 miRNA
if (sum(zero_expression_miRNAs) > 0) {
print(paste("以下 miRNA 在所有样本中表达值均为 0，将被移除：",
paste(rownames(miRNA_data_11)[zero_expression_miRNAs], collapse = ", ")))
} else {
print("没有 miRNA 在所有样本中表达值均为 0。")
}
# 6. 转置数据，因为 minet 需要样本为行，miRNA 为列
miRNA_data_t <- t(miRNA_data_11_filtered)
# 7. 使用 minet 函数构建网络（使用 mrnet 方法）
mrnet_network <- minet(miRNA_data_t, method = "mrnetb", estimator = "spearman")
# 8. 将网络转换为边列表
edges <- which(mrnet_network > 0, arr.ind = TRUE)
edge_list <- data.frame(
miRNA1 = rownames(mrnet_network)[edges[, 1]],
miRNA2 = colnames(mrnet_network)[edges[, 2]],
weight = mrnet_network[edges]
)
# 9. 使用阈值 0.5 筛选边列表
threshold <- 0.5
filtered_edge_list <- edge_list %>% filter(weight > threshold)
# 10. 保存筛选后的网络为 CSV 文件（不包含双引号）
write.csv(filtered_edge_list, "normal_miRNA_network_mrnet_threshold_0.5.csv", row.names = FALSE, quote = FALSE)
print(paste("正常样本的 miRNA 网络已保存为 'normal_miRNA_network_mrnet_threshold_0.5.csv'，阈值 =", threshold))

selected_samples <- clinical_data %>%
filter(ajcc_pathologic_stage %in% selected_stages) %>%
pull(case_submitter_id)
# 5. 提取这些样本的基因表达数据
selected_samples_full <- colnames(gene_data)[substr(colnames(gene_data), 1, 12) %in% selected_samples]
gene_data_filtered <- gene_data[, selected_samples_full, drop = FALSE]
# 6. 处理缺失值，用 0 补齐
gene_data_filtered[is.na(gene_data_filtered)] <- 0
# 7. 删除所有表达值均为 0 的基因
zero_expression_genes <- rowSums(gene_data_filtered) == 0
gene_data_filtered <- gene_data_filtered[!zero_expression_genes, ]
# 打印被删除的基因
if (sum(zero_expression_genes) > 0) {
print(paste("以下基因在所有样本中表达值均为 0，将被移除：",
paste(rownames(gene_data_filtered)[zero_expression_genes], collapse = ", ")))
} else {
print("没有基因在所有样本中表达值均为 0。")
}
# 8. 转置数据，因为 minet 需要样本为行，基因为列
gene_data_t <- t(gene_data_filtered)
# 9. 检查并移除方差为零的基因
row_variances <- apply(gene_data_t, 1, var, na.rm = TRUE)
zero_variance_genes <- names(row_variances[row_variances == 0])
if (length(zero_variance_genes) > 0) {
print(paste("以下基因的方差为零，将被移除：", paste(zero_variance_genes, collapse = ", ")))
} else {
print("没有基因的方差为零。")
}
gene_data_t_filtered <- gene_data_t[row_variances > 0, ]
# 10. 使用 minet 函数构建网络（使用 aracne 方法）
aracne_network <- minet(gene_data_t_filtered, method = "aracne", estimator = "spearman")
# 11. 将网络转换为边列表
edges <- which(aracne_network > 0, arr.ind = TRUE)
edge_list <- data.frame(
gene1 = rownames(aracne_network)[edges[, 1]],
gene2 = colnames(aracne_network)[edges[, 2]],
weight = aracne_network[edges]
)
# 12. 使用阈值 0.5 筛选边列表
threshold <- 0.5
filtered_edge_list <- edge_list %>% filter(weight > threshold)
# 13. 保存筛选后的网络为 CSV 文件（不包含双引号）
write.csv(filtered_edge_list, "stage_I_gene_network_aracne_threshold_0.5.csv", row.names = FALSE, quote = FALSE)
print(paste("Stage I 样本的基因网络已保存为 'stage_I_gene_network_aracne_threshold_0.5.csv'，阈值 =", threshold))

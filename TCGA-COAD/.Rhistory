# 1. 安装并加载所需的包
library(minet)
library(dplyr)
# 2. 加载基因表达数据
gene_data <- read.csv("filtered_hiseq_data.csv", row.names = 1, check.names = FALSE)
# 3. 加载临床信息
clinical_data <- read.csv("clinical.tsv", sep = "\t", check.names = FALSE)
# 4. 筛选临床信息中 Stage I、Stage IA 和 Stage IB 的样本
selected_stages <- c("Stage I", "Stage IA", "Stage IB")
selected_samples <- clinical_data %>%
filter(ajcc_pathologic_stage %in% selected_stages) %>%
pull(case_submitter_id)
# 5. 提取这些样本的基因表达数据
# 基因表达数据中的样本 ID 是完整的（如 TCGA-D5-6920-01），而临床信息中的样本 ID 是前 12 位（如 TCGA-D5-6920）
# 因此需要匹配前 12 位
selected_samples_full <- colnames(gene_data)[substr(colnames(gene_data), 1, 12) %in% selected_samples]
gene_data_filtered <- gene_data[, selected_samples_full, drop = FALSE]
# 6. 处理缺失值，用 0 补齐
gene_data_filtered[is.na(gene_data_filtered)] <- 0
# 7. 删除所有表达值均为 0 的基因
zero_expression_genes <- rowSums(gene_data_filtered) == 0
gene_data_filtered <- gene_data_filtered[!zero_expression_genes, ]
# 打印被删除的基因
if (sum(zero_expression_genes) > 0) {
print(paste("以下基因在所有样本中表达值均为 0，将被移除：",
paste(rownames(gene_data_filtered)[zero_expression_genes], collapse = ", ")))
} else {
print("没有基因在所有样本中表达值均为 0。")
}
# 8. 转置数据，因为 minet 需要样本为行，基因为列
gene_data_t <- t(gene_data_filtered)
# 9. 使用 minet 函数构建网络（使用 mrnet 方法）
mrnet_network <- minet(gene_data_t, method = "mrnet", estimator = "spearman")
# 10. 将网络转换为边列表
edges <- which(mrnet_network > 0, arr.ind = TRUE)
edge_list <- data.frame(
gene1 = rownames(mrnet_network)[edges[, 1]],
gene2 = colnames(mrnet_network)[edges[, 2]],
weight = mrnet_network[edges]
)
# 11. 使用阈值 0.5 筛选边列表
threshold <- 0.5
filtered_edge_list <- edge_list %>% filter(weight > threshold)
# 12. 保存筛选后的网络为 CSV 文件（不包含双引号）
write.csv(filtered_edge_list, "gene_network_stage1.csv", row.names = FALSE, quote = FALSE)
print(paste("Stage I 样本的基因网络已保存为 'gene_network_stage1.csv'，阈值 =", threshold))
